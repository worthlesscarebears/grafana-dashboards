      "targets": [
        {
          "dataset": "alliance_auth",
          "datasource": {
            "type": "mysql",
            "uid": "${DS_MYSQL}"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT \n  item.name as item,\n  owner.character_name as owner,\n  item_group.name as item_group,\n  sys.name as system,\n  main.character_name as main,\n  location.location_name as location,\n  casset.name as asset_name\nFROM alliance_auth.corptools_characterasset as casset\nJOIN corptools_eveitemtype as item\n  ON item.type_id = casset.type_id\nJOIN corptools_eveitemgroup as item_group\n  ON item_group.group_id =  item.group_id\nJOIN corptools_evelocation as location\n  ON location.location_id = casset.location_id\nJOIN corptools_mapsystem as sys\n  ON sys.system_id = location.system_id\nJOIN corptools_characteraudit as caudit\n  ON caudit.id = casset.character_id\nJOIN eveonline_evecharacter as owner\n  ON owner.id = caudit.character_id\nJOIN alliance_auth.authentication_characterownership AS own \n  ON caudit.character_id = own.character_id\nJOIN alliance_auth.authentication_userprofile AS up \n  ON own.user_id = up.user_id\nJOIN alliance_auth.eveonline_evecharacter AS main \n  ON up.main_character_id = main.id\nWHERE \n  location_flag = \"Hangar\"\n  and casset.type_id in ($item_type)\n  and sys.system_id in ($system)\n  and item_group.group_id in ($item_group)\n  and main.corporation_name in ($corporation)\n",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
      "title": "Assets",
      "type": "table"
    }

      "targets": [
        {
          "dataset": "alliance_auth",
          "datasource": {
            "type": "mysql",
            "uid": "${DS_MYSQL}"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH filtered_main_chars AS (\n    -- Pre-calculate and filter character ownership links\n    SELECT \n        caudit.id AS audit_id,\n        owner.character_name AS owner_name,\n        main.character_name AS main_name\n    FROM alliance_auth.corptools_characteraudit AS caudit\n    JOIN alliance_auth.eveonline_evecharacter AS owner ON owner.id = caudit.character_id\n    JOIN alliance_auth.authentication_characterownership AS own ON caudit.character_id = own.character_id\n    JOIN alliance_auth.authentication_userprofile AS up ON own.user_id = up.user_id\n    JOIN alliance_auth.eveonline_evecharacter AS main ON up.main_character_id = main.id\n    WHERE main.corporation_id IN ($corporation)\n),\nfiltered_locations AS (\n    -- Resolve systems and locations in one pass\n    SELECT \n        loc.location_id,\n        loc.location_name,\n        sys.name AS system_name\n    FROM alliance_auth.corptools_evelocation AS loc\n    JOIN alliance_auth.eve_sde_solarsystem AS sys ON sys.id = loc.system_id\n    WHERE sys.id IN ($system)\n),\nfiltered_items AS (\n    -- Isolate specific item types and groups\n    SELECT \n        item.id as type_id,\n        item.name AS item_name,\n        grp.name AS group_name\n    FROM alliance_auth.eve_sde_itemtype AS item\n    JOIN alliance_auth.eve_sde_itemgroup AS grp ON item.group_id = grp.id\n    WHERE item.id IN ($item_type)\n      AND item.group_id IN ($item_group)\n)\nSELECT \n    i.item_name AS item,\n    m.owner_name AS owner,\n    i.group_name AS item_group,\n    l.system_name AS system,\n    m.main_name AS main,\n    l.location_name AS location,\n    casset.name AS asset_name\nFROM alliance_auth.corptools_characterasset AS casset\nINNER JOIN filtered_main_chars m ON casset.character_id = m.audit_id\nINNER JOIN filtered_locations l ON casset.location_id = l.location_id\nINNER JOIN filtered_items i ON casset.type_name_id = i.type_id\nWHERE casset.location_flag = 'Hangar';\n",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
      "title": "Assets",
      "type": "table"
    }

          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT \n  $__timeGroupAlias(contract.date_completed, '1d'),\n  COUNT(contract.id) AS value\nFROM alliance_auth.buybackprogram_tracking as tracking\nJOIN alliance_auth.buybackprogram_program as program ON program.id = tracking.program_id\nJOIN alliance_auth.buybackprogram_contract as contract on contract.id = tracking.contract_id\nWHERE \n  $__timeFilter(contract.date_completed)\n  AND tracking.program_id IN ($program)\nGROUP BY 1\nORDER BY 1",
          "refId": "A",

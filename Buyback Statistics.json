      "targets": [
        {
          "dataset": "alliance_auth",
          "datasource": {
            "type": "mysql",
            "uid": "${DS_MYSQL}"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT \n  program.name as program_name,\n  COUNT(contract.id) as total_contracts,\n  SUM(tracking.net_price) as total_price,\n  SUM(tracking.value) as total_value,\n  SUM(contract.volume) as total_volume,\n  AVG(tracking.net_price) as average_price,\n  AVG(contract.volume) as average_volume\nFROM alliance_auth.buybackprogram_tracking as tracking\nJOIN alliance_auth.buybackprogram_program as program ON program.id = tracking.program_id\nJOIN alliance_auth.buybackprogram_contract as contract on contract.id = tracking.contract_id\nWHERE \n  $__timeFilter(contract.date_completed)\n  AND tracking.program_id IN ($program)\nGROUP BY tracking.program_id;",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
      "title": "Summary Statistics",
      "type": "stat"
    },

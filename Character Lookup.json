          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  c.character_name,\n  own.created as as_of\nFROM eveonline_evecharacter AS c\nINNER JOIN alliance_auth.authentication_ownershiprecord AS own\n  ON own.character_id = c.id\nWHERE\n  own.user_id = (\n    SELECT\n      ownership.user_id\n    FROM eveonline_evecharacter AS target\n    INNER JOIN alliance_auth.authentication_ownershiprecord AS ownership\n      ON ownership.character_id = target.id\n    WHERE\n      target.character_name = '$character'\n  );\n",
          "refId": "A",

          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  main.character_name\nFROM eveonline_evecharacter as c\nINNER JOIN alliance_auth.authentication_ownershiprecord AS own \n    ON own.character_id = c.id\nINNER JOIN alliance_auth.authentication_userprofile AS up \n    ON own.user_id = up.user_id\nINNER JOIN alliance_auth.eveonline_evecharacter AS main \n    ON up.main_character_id = main.id\nWHERE\n  c.character_name = \"$character\"\nORDER BY own.created desc\nLIMIT 1",

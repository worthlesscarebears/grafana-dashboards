        {
          "dataset": "alliance_auth",
          "datasource": {
            "type": "mysql",
            "uid": "${DS_MYSQL}"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  main.character_name,\n  corp.name,\n  SUM(lp.amount) as amount\nFROM\n  alliance_auth.corptools_loyaltypoint as lp\nJOIN alliance_auth.corptools_characteraudit as ca ON ca.id = lp.character_id\nJOIN alliance_auth.corptools_evename as corp ON corp.eve_id = lp.corporation_id\nINNER JOIN alliance_auth.authentication_characterownership AS own \n    ON ca.character_id = own.character_id\nINNER JOIN alliance_auth.authentication_userprofile AS up \n    ON own.user_id = up.user_id\nINNER JOIN alliance_auth.eveonline_evecharacter AS main \n    ON up.main_character_id = main.id\nWHERE lp.corporation_id IN ($corporation)\n  and main.corporation_id in ($main_corporation)\nGROUP BY main.id, lp.corporation_id\nORDER BY amount DESC",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
                  "type": "string"
                },
                "type": "groupBy"
              }
            ],
            "limit": 50
          }
        }
      ],
      "title": "Loyalty Point Balances",
      "type": "table"

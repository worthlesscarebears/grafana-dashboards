          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n    main.character_name,\n    SUM(char_totals.char_sum) AS total_sum\nFROM (\n    SELECT\n        installer_id,\n        COUNT(*) AS char_sum\n    FROM alliance_auth.corptools_corporationindustryjob\n    WHERE\n      $__timeFilter(start_date)\n    GROUP BY installer_id\n) AS char_totals\nINNER JOIN alliance_auth.eveonline_evecharacter as c\n    ON c.character_id = char_totals.installer_id\nINNER JOIN alliance_auth.authentication_characterownership AS own \n    ON c.id = own.character_id\nINNER JOIN alliance_auth.authentication_userprofile AS up \n    ON own.user_id = up.user_id\nINNER JOIN alliance_auth.eveonline_evecharacter AS main \n    ON up.main_character_id = main.id\nWHERE\n  main.corporation_name = \"$corporation\"\nGROUP BY\n    main.id\nORDER BY total_sum desc\nLIMIT 20;",
          "refId": "A",

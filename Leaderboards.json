        {
          "dataset": "alliance_auth",
          "datasource": {
            "type": "mysql",
            "uid": "${DS_MYSQL}"
          },
          "editorMode": "code",
          "format": "table",
          "hide": false,
          "rawQuery": true,
          "rawSql": "SELECT\n    main.character_name,\n    SUM(char_totals.char_sum) AS total_sum\nFROM (\n    SELECT\n        character_id,\n        SUM(amount) AS char_sum\n    FROM alliance_auth.corptools_characterwalletjournalentry\n    WHERE ref_type = \"bounty_prizes\"\n        AND $__timeFilter(date)\n    GROUP BY character_id\n) AS char_totals\nINNER JOIN alliance_auth.corptools_characteraudit as ca\n    ON ca.id = char_totals.character_id\nINNER JOIN alliance_auth.authentication_characterownership AS own \n    ON ca.character_id = own.character_id\nINNER JOIN alliance_auth.authentication_userprofile AS up \n    ON own.user_id = up.user_id\nINNER JOIN alliance_auth.eveonline_evecharacter AS main \n    ON up.main_character_id = main.id\nWHERE\n  main.corporation_name = \"$corporation\"\nGROUP BY\n    main.id\nORDER BY total_sum desc\nLIMIT 20;",
          "refId": "C",
          "sql": {
            "columns": [

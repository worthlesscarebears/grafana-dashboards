      "targets": [
        {
          "dataset": "alliance_auth",
          "datasource": {
            "type": "mysql",
            "uid": "${DS_MYSQL}"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "WITH top_miners AS (\n    SELECT\n        up.main_character_id,\n        SUM(ledger.quantity) AS grand_total\n    FROM alliance_auth.corptools_characterminingledger AS ledger\n    INNER JOIN alliance_auth.corptools_characteraudit AS ca \n        ON ca.id = ledger.character_id\n    INNER JOIN alliance_auth.authentication_characterownership AS own \n        ON ca.character_id = own.character_id\n    INNER JOIN alliance_auth.authentication_userprofile AS up \n        ON own.user_id = up.user_id\n    INNER JOIN alliance_auth.eveonline_evecharacter AS main \n        ON up.main_character_id = main.id\n    WHERE $__timeFilter(ledger.date)\n      AND main.corporation_name = \"$corporation\"\n    GROUP BY up.main_character_id\n    ORDER BY grand_total DESC\n    LIMIT 20\n)\nSELECT\n    main.character_name,\n    ig.name,\n    SUM(ledger.quantity) AS total_sum,\n    tm.grand_total\nFROM alliance_auth.corptools_characterminingledger AS ledger\nINNER JOIN alliance_auth.corptools_eveitemtype AS it \n    ON it.type_id = ledger.type_name_id\nINNER JOIN alliance_auth.corptools_eveitemgroup AS ig \n    ON ig.group_id = it.group_id\nINNER JOIN alliance_auth.corptools_characteraudit AS ca \n    ON ca.id = ledger.character_id\nINNER JOIN alliance_auth.authentication_characterownership AS own \n    ON ca.character_id = own.character_id\nINNER JOIN alliance_auth.authentication_userprofile AS up \n    ON own.user_id = up.user_id\nINNER JOIN alliance_auth.eveonline_evecharacter AS main \n    ON up.main_character_id = main.id\nINNER JOIN top_miners AS tm\n    ON main.id = tm.main_character_id\nWHERE $__timeFilter(ledger.date)\nGROUP BY main.id, ig.group_id, tm.grand_total\nORDER BY tm.grand_total DESC, total_sum DESC",
          "refId": "A",
          "sql": {
            "columns": [
              {
                "parameters": [],
                "type": "function"
              }
            ],
            "groupBy": [
              {
                "property": {
